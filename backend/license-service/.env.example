PORT=3000
ENHE_PUBLIC_BASE_URL=https://www.enhe-tech.com.cn

# Optional production database. If empty, the service uses LICENSE_SERVICE_STATE_FILE.
DATABASE_URL=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

LICENSE_PEPPER=
LICENSE_SERVICE_STATE_FILE=./var/license-service-state.json

# Hosted worker isolation.
PROMOTION_REPO_ROOT=/opt/enhe/promotion-manager/current
HOSTED_RUN_OUTPUT_ROOT=/var/lib/enhe-promotion-manager/hosted-runs
HOSTED_RUN_TIMEOUT_MS=1800000
HOSTED_WORKER_ENABLED=false
HOSTED_WORKER_INTERVAL_MS=15000
HOSTED_WORKER_MODE=execute
ALLOW_PRIVATE_PRODUCT_URLS=
PYTHON_BIN=python3
