NODE_ENV=production
PORT=3030
ENHE_PUBLIC_BASE_URL=https://www.enhe-tech.com.cn

DATABASE_URL=postgres://enhe_promotion_manager:CHANGE_ME@127.0.0.1:5432/enhe_promotion_manager

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_SCALE=

# Domestic checkout. Reuse the ENHE website ZPAY merchant values server-side.
ZPAY_API_BASE=https://zpayz.cn
ZPAY_PID=
ZPAY_KEY=
ZPAY_DEFAULT_TYPE=wxpay
ZPAY_CHANNEL_ID=
ZPAY_PRICE_STARTER_CNY=19
ZPAY_PRICE_GROWTH_CNY=59
ZPAY_PRICE_SCALE_CNY=199
ZPAY_LICENSE_DAYS=30

LICENSE_PEPPER=
LICENSE_SERVICE_STATE_FILE=/var/lib/enhe-promotion-manager/license-service-state.json

PROMOTION_REPO_ROOT=/opt/enhe/promotion-manager/current
HOSTED_RUN_OUTPUT_ROOT=/var/lib/enhe-promotion-manager/hosted-runs
HOSTED_RUN_TIMEOUT_MS=1800000
HOSTED_ARTIFACT_RETENTION_DAYS=30
SECURITY_AUDIT_LOG_RETENTION_DAYS=180
RETENTION_CLEANUP_INTERVAL_MS=21600000
HOSTED_WORKER_ENABLED=false
HOSTED_WORKER_INTERVAL_MS=15000
HOSTED_WORKER_MODE=execute
ALLOW_PRIVATE_PRODUCT_URLS=
PYTHON_BIN=/opt/enhe/promotion-manager/venv/bin/python
